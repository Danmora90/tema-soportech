{% doc %}
  Renders a product card for grids.

  @param {product} product - The product object to display

  @example
  {% render 'product-card', product: product %}
{% enddoc %}

{%- assign has_sale = false -%}
{%- if product.compare_at_price > product.price -%}
  {%- assign has_sale = true -%}
  {%- assign savings_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
{%- endif -%}

<article class="pc">
  <!-- Image -->
  <a class="pc__img-wrap" href="{{ product.url }}" tabindex="-1" aria-hidden="true">
    {%- if has_sale -%}
      <span class="pc__badge">-{{ savings_pct | round }}%</span>
    {%- elsif product.available == false -%}
      <span class="pc__badge pc__badge--sold-out">Agotado</span>
    {%- endif -%}

    {%- if product.featured_image -%}
      {{
        product.featured_image
        | image_url: width: 800
        | image_tag:
          loading: 'lazy',
          widths: '360, 540, 720, 800',
          sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw',
          class: 'pc__img',
          alt: product.featured_image.alt | default: product.title
      }}
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'pc__img pc__img--placeholder' }}
    {%- endif -%}

    {%- if product.images[1] -%}
      {{
        product.images[1]
        | image_url: width: 800
        | image_tag:
          loading: 'lazy',
          class: 'pc__img pc__img--hover',
          alt: product.title
      }}
    {%- endif -%}
  </a>

  <!-- Info -->
  <div class="pc__info">
    {%- if product.vendor != blank -%}
      <span class="pc__vendor">{{ product.vendor }}</span>
    {%- endif -%}

    <h3 class="pc__title">
      <a href="{{ product.url }}">{{ product.title | truncate: 55 }}</a>
    </h3>

    <div class="pc__price-row">
      {%- if has_sale -%}
        <span class="pc__price pc__price--sale">{{ product.price | money }}</span>
        <span class="pc__price pc__price--compare"><s>{{ product.compare_at_price | money }}</s></span>
      {%- else -%}
        <span class="pc__price">{{ product.price | money }}</span>
      {%- endif -%}
    </div>

    {%- if product.available -%}
      {%- form 'product', product, class: 'pc__form' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button type="submit" name="add" class="pc__atc">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="3" y1="6" x2="21" y2="6" stroke="currentColor" stroke-width="1.8"/>
            <path d="M16 10a4 4 0 01-8 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Agregar al carrito
        </button>
      {%- endform -%}
    {%- else -%}
      <button class="pc__atc pc__atc--disabled" disabled>Agotado</button>
    {%- endif -%}
  </div>
</article>

{% stylesheet %}
  /* ── Product Card ── */
  .pc {
    background: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      transform  0.26s cubic-bezier(0.34, 1.4, 0.64, 1),
      box-shadow 0.26s ease,
      border-color 0.26s ease;
    height: 100%;
  }

  .pc:hover {
    transform: translateY(-5px);
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.07),
      0 20px 48px -8px rgba(0, 0, 0, 0.12);
    border-color: #d1d5db;
  }

  /* ── Image area ── */
  .pc__img-wrap {
    position: relative;
    display: block;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: #ffffff;
  }

  .pc__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    padding: 0.75rem;
    display: block;
    transition: transform 0.5s ease, opacity 0.35s ease;
  }


  .pc__img--hover {
    position: absolute;
    inset: 0;
    opacity: 0;
  }

  .pc__img-wrap:hover .pc__img:first-of-type  { opacity: 0; transform: scale(1.04); }
  .pc__img-wrap:hover .pc__img--hover          { opacity: 1; transform: scale(1.04); }

  .pc__img--placeholder {
    padding: 2rem;
    fill: #d1d5db;
    background: #f3f4f6;
  }

  /* ── Badge ── */
  .pc__badge {
    position: absolute;
    top: 0.625rem;
    left: 0.625rem;
    z-index: 2;
    padding: 0.25rem 0.6rem;
    font-size: 0.6875rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    border-radius: 0.3rem;
    background: #22c55e;
    color: #ffffff;
    white-space: nowrap;
  }

  .pc__badge--sold-out {
    background: #6b7280;
  }

  /* ── Card info ── */
  .pc__info {
    padding: 0.875rem 1rem 1.125rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }

  .pc__vendor {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #06b6d4;
  }

  .pc__title {
    margin: 0;
    font-size: 0.875rem;
    font-weight: 600;
    line-height: 1.35;
    flex: 1;
  }

  .pc__title a {
    color: #0f172a;
    text-decoration: none;
    transition: color 0.18s;
  }

  .pc__title a:hover { color: #06b6d4; }

  /* ── Prices ── */
  .pc__price-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.2rem;
  }

  .pc__price {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
  }

  .pc__price--sale {
    font-size: 1.0625rem;
    color: #0f172a;
  }

  .pc__price--compare {
    font-size: 0.8125rem;
    font-weight: 400;
    color: #9ca3af;
  }

  .pc__price--compare s { text-decoration: line-through; }

  /* ── Add to Cart ── */
  .pc__form { margin-top: auto; padding-top: 0.75rem; }

  .pc__atc {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    width: 100%;
    padding: 0.7rem 1rem;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #ffffff;
    background: #0f172a;
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      transform        0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    -webkit-appearance: none;
  }

  .pc__atc:hover {
    background-color: #06b6d4;
    transform: scale(1.03);
  }

  .pc__atc--disabled {
    background: #e5e7eb;
    color: #9ca3af;
    cursor: not-allowed;
  }

  .pc__atc--disabled:hover {
    background: #e5e7eb;
    transform: none;
  }
{% endstylesheet %}
