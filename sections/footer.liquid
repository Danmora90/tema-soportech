<footer class="site-footer full-width" {{ section.shopify_attributes }}>
  <div class="footer-top-accent"></div>

  <div class="footer-container">
    <div class="footer-grid">

      {%- comment -%} Col 1: Brand & Socials {%- endcomment -%}
      <div class="footer-col footer-col-brand">
        <a href="{{ routes.root_url }}" class="footer-logo-link">
          {%- if section.settings.logo_image != blank -%}
            {{ section.settings.logo_image | image_url: width: 220 | image_tag: class: 'footer-logo-img', alt: shop.name }}
          {%- elsif section.settings.logo_svg != blank -%}
            {{ section.settings.logo_svg }}
          {%- else -%}
            <span class="footer-logo-text">{{ shop.name }}</span>
          {%- endif -%}
        </a>

        {%- if section.settings.show_social -%}
          <div class="footer-social-wrapper">
            <span class="footer-social-title">SÍGUENOS</span>
            <div class="footer-social-icons">
              {%- if settings.social_facebook_link != blank -%}
                <a href="{{ settings.social_facebook_link }}" class="social-icon" target="_blank" rel="noopener" aria-label="Facebook">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                </a>
              {%- endif -%}
              {%- if settings.social_instagram_link != blank -%}
                <a href="{{ settings.social_instagram_link }}" class="social-icon" target="_blank" rel="noopener" aria-label="Instagram">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                </a>
              {%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}
                <a href="{{ settings.social_tiktok_link }}" class="social-icon" target="_blank" rel="noopener" aria-label="TikTok">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1-.1z"/></svg>
                </a>
              {%- endif -%}
              {%- if section.settings.wa_number != blank -%}
                <a href="https://wa.me/{{ section.settings.wa_number | remove: '+' | remove: ' ' | remove: '-' }}" class="social-icon" target="_blank" rel="noopener" aria-label="WhatsApp">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Col 2: Nosotros {%- endcomment -%}
      <div class="footer-col">
        <h3 class="footer-col-title">Nosotros</h3>
        <ul class="footer-menu">
          <li><a href="/pages/quienes-somos">Quienes somos</a></li>
          <li><a href="/pages/nuestras-tiendas">Nuestras Tiendas</a></li>
        </ul>
      </div>

      {%- comment -%} Col 3: Información Legal {%- endcomment -%}
      <div class="footer-col">
        <h3 class="footer-col-title">Información Legal</h3>
        <ul class="footer-menu">
          <li><a href="/pages/aviso-de-privacidad">Aviso de privacidad</a></li>
          <li><a href="/pages/politica-de-tratamiento-de-la-informacion">Política de tratamiento de la información</a></li>
          <li><a href="/pages/politica-de-pago-envio-y-derecho-de-retracto">Política de pago en línea, envío y derecho de retracto</a></li>
          <li><a href="/pages/politicas-de-garantia">Políticas de garantía</a></li>
          <li><a href="https://www.sic.gov.co" target="_blank" rel="noopener">Entidad de protección al consumidor www.sic.gov.co</a></li>
        </ul>
      </div>

      {%- comment -%} Col 4: Ayuda {%- endcomment -%}
      <div class="footer-col">
        <h3 class="footer-col-title">Ayuda</h3>
        <ul class="footer-menu">
          <li><a href="/pages/servicio-al-cliente">Servicio al Cliente</a></li>
          <li><a href="/pages/seguimiento-a-mi-pedido">Seguimiento a mi Pedido</a></li>
          <li><a href="/pages/preguntas-frecuentes">Preguntas Frecuentes</a></li>
          <li><a href="/pages/pqrs">PQRS</a></li>
        </ul>
      </div>

    </div>

    {%- comment -%} Fila de métodos de pago centrada {%- endcomment -%}
    {%- if section.settings.show_payment_icons -%}
      <div class="footer-payments-row">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'payment-icon' }}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Copyright {%- endcomment -%}
    <div class="footer-bottom">
      <p class="footer-copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

{%- comment -%} Floating WhatsApp Button {%- endcomment -%}
{%- if section.settings.wa_number != blank -%}
  <a href="https://wa.me/{{ section.settings.wa_number | remove: '+' | remove: ' ' | remove: '-' }}" target="_blank" rel="noopener" class="wa-float-btn" aria-label="Escríbenos por WhatsApp">
    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
{%- endif -%}

{% stylesheet %}
  /* ══ FOOTER ══ */
  .site-footer {
    position: relative;
    background-color: #080f1a;
    color: #9ca3af;
    font-family: inherit;
  }

  /* Línea decorativa cyan en la parte superior */
  .footer-top-accent {
    height: 3px;
    background: linear-gradient(90deg, transparent 0%, #06b6d4 40%, #3b82f6 60%, transparent 100%);
    opacity: 0.8;
  }

  .footer-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 2rem 2rem;
  }

  /* Grid: 1 col mobile → 2 cols tablet → 4 cols desktop */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  @media screen and (min-width: 640px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media screen and (min-width: 1024px) {
    .footer-grid { grid-template-columns: 1.4fr 1fr 1.6fr 1fr; gap: 2.5rem; }
  }

  /* ── Brand column ── */
  .footer-col-brand { display: flex; flex-direction: column; gap: 0; }

  .footer-logo-link {
    display: inline-block;
    margin-bottom: 1.75rem;
    text-decoration: none;
  }

  .footer-logo-img {
    max-height: 52px;
    width: auto;
    object-fit: contain;
  }

  .footer-col-brand svg { max-height: 52px; width: auto; fill: #ffffff; }

  .footer-logo-text {
    font-size: 1.625rem;
    font-weight: 900;
    color: #ffffff;
    margin: 0;
    letter-spacing: -0.02em;
  }

  /* ── Sociales ── */
  .footer-social-wrapper { display: flex; flex-direction: column; gap: 0.75rem; }

  .footer-social-title {
    font-size: 0.75rem;
    font-weight: 700;
    color: #06b6d4;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .footer-social-icons { display: flex; gap: 0.625rem; align-items: center; }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    color: #9ca3af;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 50%;
    transition: color 0.25s ease, border-color 0.25s ease, background 0.25s ease, transform 0.25s ease;
  }

  .social-icon svg { width: 18px; height: 18px; }

  .social-icon:hover {
    color: #06b6d4;
    border-color: #06b6d4;
    background: rgba(6,182,212,0.08);
    transform: translateY(-3px);
  }

  /* ── Link columns ── */
  .footer-col-title {
    font-size: 0.8125rem;
    font-weight: 800;
    color: #06b6d4;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 1.25rem 0;
  }

  .footer-menu {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer-menu a {
    color: #9ca3af;
    text-decoration: none;
    font-size: 0.9rem;
    line-height: 1.4;
    transition: color 0.2s ease, padding-left 0.2s ease;
    display: inline-block;
  }

  .footer-menu a:hover { color: #ffffff; padding-left: 4px; }

  /* ── Payment icons row (centrada) ── */
  .footer-payments-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    padding: 2rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .payment-icon {
    height: 26px;
    width: auto;
    filter: grayscale(100%) brightness(0.65);
    transition: filter 0.3s ease;
  }

  .payment-icon:hover { filter: grayscale(0%) brightness(1); }

  /* ── Copyright bar ── */
  .footer-bottom {
    padding-top: 1.5rem;
    text-align: center;
  }

  .footer-copyright { font-size: 0.8125rem; color: #6b7280; margin: 0; }

  /* ── WhatsApp Float ── */
  .wa-float-btn {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    background-color: #25d366;
    color: white;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.3);
    z-index: 50;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    animation: wa-pulse 2s infinite;
  }

  .wa-float-btn svg { width: 34px; height: 34px; }

  .wa-float-btn:hover {
    transform: scale(1.1) translateY(-4px);
    animation: none;
    box-shadow: 0 20px 25px -5px rgba(0,0,0,0.4);
  }

  @keyframes wa-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(37,211,102,0.7); }
    70%  { box-shadow: 0 0 0 14px rgba(37,211,102,0); }
    100% { box-shadow: 0 0 0 0 rgba(37,211,102,0); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Pie de página (Footer)",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo (imagen)",
      "info": "Recomendado: PNG con fondo transparente, versión clara/blanca del logo."
    },
    {
      "type": "html",
      "id": "logo_svg",
      "label": "Logo SVG (código alternativo)",
      "info": "Solo se usa si no hay imagen seleccionada arriba."
    },
    {
      "type": "header",
      "content": "Redes Sociales"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Mostrar iconos de redes sociales",
      "default": true,
      "info": "Configura los enlaces en Configuración del Tema → Redes Sociales"
    },
    {
      "type": "header",
      "content": "Sub-footer"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Mostrar métodos de pago",
      "default": true
    },
    {
      "type": "header",
      "content": "Botón flotante de WhatsApp"
    },
    {
      "type": "text",
      "id": "wa_number",
      "label": "Número de WhatsApp con código de país",
      "placeholder": "+573001234567"
    }
  ],
  "max_blocks": 3,
  "blocks": [
    {
      "type": "link_list",
      "name": "Columna de links",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título de la columna",
          "default": "Enlaces"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menú de navegación"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pie de página Premium",
      "blocks": [
        { "type": "link_list" },
        { "type": "link_list" },
        { "type": "link_list" }
      ]
    }
  ]
}
{% endschema %}
