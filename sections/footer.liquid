<footer class="site-footer full-width" {{ section.shopify_attributes }}>
  <div class="footer-container">
    <div class="footer-grid">
      
      {%- comment -%} Col 1: Brand & Socials {%- endcomment -%}
      <div class="footer-col footer-col-brand">
        <a href="{{ routes.root_url }}" class="footer-logo-link">
          {%- if section.settings.logo_svg != blank -%}
            {{ section.settings.logo_svg }}
          {%- else -%}
            <h2 class="footer-logo-text">{{ shop.name }}</h2>
          {%- endif -%}
        </a>
        
        {%- if section.settings.show_social -%}
          <div class="footer-social-wrapper">
            <span class="footer-social-title">SÍGUENOS</span>
            <div class="footer-social-icons">
              {%- if settings.social_facebook_link != blank -%}
                <a href="{{ settings.social_facebook_link }}" class="social-icon" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"></path></svg>
                </a>
              {%- endif -%}
              {%- if settings.social_instagram_link != blank -%}
                <a href="{{ settings.social_instagram_link }}" class="social-icon" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                </a>
              {%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}
                <a href="{{ settings.social_tiktok_link }}" class="social-icon" target="_blank" rel="noopener">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"></path></svg>
                </a>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Disabling block loop manually, using direct blocks based on order for columns 2, 3, 4 {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_list' -%}
            <div class="footer-col" {{ block.shopify_attributes }}>
              <h3 class="footer-col-title">{{ block.settings.heading | escape }}</h3>
              {%- if block.settings.menu != blank -%}
                <ul class="footer-menu">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}

    </div>

    {%- comment -%} Sub-footer (Copyright & Payments) {%- endcomment -%}
    <div class="footer-bottom">
      <div class="footer-copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Todos los derechos reservados.
      </div>

      {%- if section.settings.show_payment_icons -%}
        <div class="footer-payments">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{%- comment -%} Floating WhatsApp Button {%- endcomment -%}
{%- if section.settings.wa_number != blank -%}
  <a href="https://wa.me/{{ section.settings.wa_number | remove: '+' | remove: ' ' | remove: '-' }}" target="_blank" rel="noopener" class="wa-float-btn" aria-label="Escríbenos por WhatsApp">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
    </svg>
  </a>
{%- endif -%}

{% stylesheet %}
  .site-footer {
    position: relative;
    background-color: #0A0A0A;
    color: #9CA3AF;
    padding: 4rem 0 2rem;
    font-family: inherit;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 3rem;
  }

  @media screen and (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .footer-col-brand .footer-logo-link {
    display: inline-block;
    margin-bottom: 2rem;
    text-decoration: none;
  }

  .footer-col-brand svg {
    max-height: 48px;
    width: auto;
    fill: #ffffff;
  }

  .footer-logo-text {
    font-size: 1.5rem;
    font-weight: 800;
    color: #ffffff;
    margin: 0;
  }

  .footer-social-title {
    display: block;
    font-size: 0.875rem;
    font-weight: 700;
    color: #06B6D4;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }

  .footer-social-icons {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: #ffffff;
    transition: all 0.3s ease;
    border-radius: 50%;
    background-color: rgba(255,255,255,0.05);
  }

  .social-icon svg {
    width: 20px;
    height: 20px;
  }

  .social-icon:hover {
    color: #06B6D4;
    background-color: rgba(6, 182, 212, 0.1);
    transform: translateY(-2px);
  }

  .footer-col-title {
    font-size: 1rem;
    font-weight: 700;
    color: #06B6D4;
    text-transform: uppercase;
    margin: 0 0 1.5rem 0;
    letter-spacing: 0.05em;
  }

  .footer-menu {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-menu a {
    color: #9CA3AF;
    text-decoration: none;
    font-size: 0.9375rem;
    transition: color 0.3s ease;
  }

  .footer-menu a:hover {
    color: #ffffff;
  }

  .footer-bottom {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid #1f2937;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  @media screen and (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer-copyright {
    font-size: 0.875rem;
  }

  .footer-payments {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
  }

  .payment-icon {
    width: 38px;
    height: auto;
    filter: grayscale(100%) opacity(0.7);
    transition: filter 0.3s ease;
  }

  .payment-icon:hover {
    filter: grayscale(0%) opacity(1);
  }

  /* WhatsApp Floating Button */
  .wa-float-btn {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    background-color: #25D366;
    color: white;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3);
    z-index: 50;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    animation: wa-pulse 2s infinite;
  }

  .wa-float-btn svg {
    width: 36px;
    height: 36px;
  }

  .wa-float-btn:hover {
    transform: scale(1.1) translateY(-4px);
    animation: none;
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.4);
  }

  @keyframes wa-pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.7);
    }
    70% {
      box-shadow: 0 0 0 15px rgba(37, 211, 102, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(37, 211, 102, 0);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Pie de página (Footer)",
  "settings": [
    {
      "type": "header",
      "content": "Marca y Redes"
    },
    {
      "type": "html",
      "id": "logo_svg",
      "label": "Logo en formato SVG (Código)"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Mostrar iconos de redes sociales",
      "default": true,
      "info": "Configura los enlaces en Configuración del Tema > Redes Sociales"
    },
    {
      "type": "header",
      "content": "Sub-footer"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Mostrar iconos de pago",
      "default": true
    },
    {
      "type": "header",
      "content": "Botón flotante de WhatsApp"
    },
    {
      "type": "text",
      "id": "wa_number",
      "label": "Número de WhatsApp con código de país (Ej: +573001234567)"
    }
  ],
  "max_blocks": 3,
  "blocks": [
    {
      "type": "link_list",
      "name": "Menú",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título del menú",
          "default": "Enlaces útiles"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Selecciona un menú"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pie de página Premium",
      "blocks": [
        { "type": "link_list" },
        { "type": "link_list" },
        { "type": "link_list" }
      ]
    }
  ]
}
{% endschema %}
