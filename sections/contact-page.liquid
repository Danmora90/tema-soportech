<section class="contact-page full-width" {{ section.shopify_attributes }}>

  {%- comment -%} ══ HERO ══ {%- endcomment -%}
  <div class="contact-hero">
    <div class="contact-hero__inner">
      <p class="contact-hero__eyebrow">
        <span class="contact-hero__dot" aria-hidden="true"></span>
        {{ section.settings.eyebrow | default: 'Estamos aquí para ayudarte' }}
        <span class="contact-hero__dot" aria-hidden="true"></span>
      </p>
      <h1 class="contact-hero__heading">{{ section.settings.hero_title | default: 'Contáctanos' }}</h1>
      <p class="contact-hero__subtext">{{ section.settings.hero_text | default: 'Completa el formulario y te responderemos a la brevedad, o si lo prefieres, llámanos o escríbenos directamente por WhatsApp.' }}</p>

      <div class="contact-hero__channels">
        {%- if section.settings.phone != blank -%}
          <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="contact-channel contact-channel--phone">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            <span>{{ section.settings.phone }}</span>
          </a>
        {%- endif -%}
        {%- if section.settings.whatsapp != blank -%}
          <a href="https://wa.me/{{ section.settings.whatsapp | remove: '+' | remove: ' ' | remove: '-' }}" target="_blank" rel="noopener" class="contact-channel contact-channel--wa">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            <span>WhatsApp</span>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%} ══ MAIN BODY ══ {%- endcomment -%}
  <div class="contact-body">
    <div class="contact-container">

      {%- comment -%} ── Left info column ── {%- endcomment -%}
      <div class="contact-info">
        <h2 class="contact-info__title">{{ section.settings.info_title | default: '¿Cómo podemos ayudarte?' }}</h2>
        <p class="contact-info__text">{{ section.settings.info_text | default: 'Nuestro equipo está disponible para asesorarte sobre equipos de audio, soporte técnico, cotizaciones y más. No dudes en contactarnos por cualquier canal.' }}</p>

        <ul class="contact-info__list">
          {%- if section.settings.email != blank -%}
            <li class="contact-info__item">
              <span class="contact-info__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>
              </span>
              <div>
                <span class="contact-info__label">Correo electrónico</span>
                <a href="mailto:{{ section.settings.email }}" class="contact-info__value">{{ section.settings.email }}</a>
              </div>
            </li>
          {%- endif -%}

          {%- if section.settings.phone != blank -%}
            <li class="contact-info__item">
              <span class="contact-info__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.68A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              </span>
              <div>
                <span class="contact-info__label">Teléfono / WhatsApp</span>
                <a href="tel:{{ section.settings.phone | remove: ' ' }}" class="contact-info__value">{{ section.settings.phone }}</a>
              </div>
            </li>
          {%- endif -%}

          {%- if section.settings.address != blank -%}
            <li class="contact-info__item">
              <span class="contact-info__icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </span>
              <div>
                <span class="contact-info__label">Ubicación</span>
                <span class="contact-info__value">{{ section.settings.address }}</span>
              </div>
            </li>
          {%- endif -%}
        </ul>
      </div>

      {%- comment -%} ── Right form column ── {%- endcomment -%}
      <div class="contact-form-wrap">
        {%- form 'contact', id: 'contact-form' -%}

          {%- if form.posted_successfully? -%}
            <div class="contact-success" role="alert">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <p>¡Mensaje enviado! Te responderemos pronto.</p>
            </div>
          {%- endif -%}

          {%- if form.errors -%}
            <div class="contact-error" role="alert">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <p>{{ form.errors | default_errors }}</p>
            </div>
          {%- endif -%}

          <div class="contact-form__grid">
            <div class="contact-form__field">
              <label for="contact-name" class="contact-form__label">Nombre <span aria-hidden="true">*</span></label>
              <input
                id="contact-name"
                type="text"
                name="contact[name]"
                class="contact-form__input"
                placeholder="Tu nombre completo"
                autocomplete="name"
                required
                value="{{ form.name }}"
              >
            </div>

            <div class="contact-form__field">
              <label for="contact-phone" class="contact-form__label">Teléfono</label>
              <input
                id="contact-phone"
                type="tel"
                name="contact[phone]"
                class="contact-form__input"
                placeholder="Ej: +57 300 123 4567"
                autocomplete="tel"
                value="{{ form.phone }}"
              >
            </div>

            <div class="contact-form__field contact-form__field--full">
              <label for="contact-email" class="contact-form__label">Correo electrónico <span aria-hidden="true">*</span></label>
              <input
                id="contact-email"
                type="email"
                name="contact[email]"
                class="contact-form__input"
                placeholder="tucorreo@ejemplo.com"
                autocomplete="email"
                required
                value="{{ form.email }}"
              >
            </div>

            <div class="contact-form__field contact-form__field--full">
              <label for="contact-body" class="contact-form__label">Solicitud, inquietud o reclamo <span aria-hidden="true">*</span></label>
              <textarea
                id="contact-body"
                name="contact[body]"
                class="contact-form__textarea"
                rows="6"
                placeholder="Cuéntanos en qué podemos ayudarte..."
                required
              >{{ form.body }}</textarea>
            </div>
          </div>

          <button type="submit" id="contact-submit" class="contact-form__btn">
            <span>Enviar mensaje</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>

        {%- endform -%}
      </div>

    </div>
  </div>
</section>

{% stylesheet %}
  /* ══════════════════════════════════════════
     CONTACT PAGE — Soportech Premium Light
  ══════════════════════════════════════════ */

  /* ── Hero ── */
  .contact-hero {
    background:
      radial-gradient(ellipse 80% 60% at 30% 0%, rgba(6,182,212,0.18) 0%, transparent 55%),
      radial-gradient(ellipse 60% 70% at 80% 100%, rgba(59,130,246,0.12) 0%, transparent 55%),
      linear-gradient(160deg, #f0f9ff 0%, #ffffff 45%, #eff6ff 100%);
    padding: 6rem 1.5rem 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .contact-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px;
    opacity: 0.025;
    pointer-events: none;
  }

  .contact-hero__inner {
    position: relative;
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .contact-hero__eyebrow {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #0891b2;
    border: 1px solid rgba(6,182,212,0.35);
    border-radius: 999px;
    padding: 0.35rem 1rem;
    background: rgba(6,182,212,0.08);
    backdrop-filter: blur(4px);
  }

  .contact-hero__dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #06b6d4;
    box-shadow: 0 0 6px #06b6d4;
    animation: cp-dot-pulse 2s ease-in-out infinite;
  }

  @keyframes cp-dot-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.7); }
  }

  .contact-hero__heading {
    margin: 0;
    font-size: clamp(2.25rem, 6vw, 4rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #0f172a 0%, #0e7490 50%, #2563eb 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .contact-hero__subtext {
    margin: 0;
    font-size: clamp(0.9375rem, 2vw, 1.125rem);
    line-height: 1.7;
    color: #475569;
    max-width: 560px;
  }

  .contact-hero__channels {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .contact-channel {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.2s ease;
  }

  .contact-channel--phone {
    background: #ffffff;
    color: #0f172a;
    border: 1px solid rgba(6,182,212,0.25);
    box-shadow: 0 2px 12px rgba(6,182,212,0.1);
  }
  .contact-channel--phone:hover {
    background: #f0f9ff;
    border-color: rgba(6,182,212,0.5);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(6,182,212,0.18);
  }

  .contact-channel--wa {
    background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
    color: #ffffff;
    box-shadow: 0 4px 20px rgba(37,211,102,0.3);
  }
  .contact-channel--wa:hover {
    transform: translateY(-2px) scale(1.04);
    box-shadow: 0 8px 30px rgba(37,211,102,0.45);
  }

  /* ── Main body ── */
  .contact-body {
    background:
      radial-gradient(ellipse 70% 50% at 100% 0%, rgba(59,130,246,0.07) 0%, transparent 60%),
      radial-gradient(ellipse 60% 40% at 0% 100%, rgba(6,182,212,0.06) 0%, transparent 60%),
      #f8fafc;
    padding: 5rem 1.5rem 6rem;
  }

  .contact-container {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem;
  }

  @media (min-width: 900px) {
    .contact-container {
      grid-template-columns: 1fr 1.4fr;
      gap: 5rem;
    }
  }

  /* ── Info column ── */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .contact-info__title {
    margin: 0;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    line-height: 1.2;
    background: linear-gradient(135deg, #0f172a 0%, #0e7490 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .contact-info__text {
    margin: 0;
    font-size: 1rem;
    line-height: 1.75;
    color: #64748b;
  }

  .contact-info__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-info__item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .contact-info__icon {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    border-radius: 0.625rem;
    background: linear-gradient(135deg, rgba(6,182,212,0.12) 0%, rgba(59,130,246,0.08) 100%);
    border: 1px solid rgba(6,182,212,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0891b2;
    margin-top: 2px;
  }

  .contact-info__label {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #94a3b8;
    margin-bottom: 0.25rem;
  }

  .contact-info__value {
    display: block;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #0f172a;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a.contact-info__value:hover { color: #0891b2; }

  /* ── Form column ── */
  .contact-form-wrap {
    background: #ffffff;
    border: 1px solid rgba(6,182,212,0.15);
    border-radius: 1.25rem;
    padding: 2.5rem;
    box-shadow: 0 4px 32px rgba(6,182,212,0.08), 0 1px 4px rgba(0,0,0,0.04);
  }

  .contact-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 600px) {
    .contact-form__grid { grid-template-columns: 1fr; }
    .contact-form__field--full { grid-column: auto; }
  }

  .contact-form__field--full { grid-column: 1 / -1; }

  .contact-form__label {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #334155;
    margin-bottom: 0.5rem;
    letter-spacing: 0.03em;
  }

  .contact-form__label span { color: #0891b2; }

  .contact-form__input,
  .contact-form__textarea {
    width: 100%;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 0.625rem;
    padding: 0.875rem 1rem;
    font-size: 0.9375rem;
    color: #0f172a;
    font-family: inherit;
    transition: border-color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    outline: none;
    box-sizing: border-box;
  }

  .contact-form__input::placeholder,
  .contact-form__textarea::placeholder { color: #94a3b8; }

  .contact-form__input:focus,
  .contact-form__textarea:focus {
    border-color: #06b6d4;
    background: #f0f9ff;
    box-shadow: 0 0 0 3px rgba(6,182,212,0.12);
  }

  .contact-form__textarea { resize: vertical; min-height: 130px; }

  .contact-form__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    width: 100%;
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #000000;
    background: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%);
    border: none;
    border-radius: 0.625rem;
    cursor: pointer;
    box-shadow: 0 0 20px rgba(6,182,212,0.35), 0 4px 24px rgba(6,182,212,0.2);
    transition: transform 0.2s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.2s ease;
    font-family: inherit;
  }

  .contact-form__btn:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 0 36px rgba(6,182,212,0.55), 0 8px 32px rgba(6,182,212,0.35);
  }

  .contact-form__btn svg { transition: transform 0.2s ease; }
  .contact-form__btn:hover svg { transform: translateX(3px) translateY(-2px); }

  /* ── Success / Error states ── */
  .contact-success,
  .contact-error {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem 1.25rem;
    border-radius: 0.625rem;
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
    font-weight: 500;
  }

  .contact-success {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    color: #15803d;
  }

  .contact-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #dc2626;
  }

  .contact-success p,
  .contact-error p { margin: 0; }

  @media (prefers-reduced-motion: reduce) {
    .contact-hero__dot { animation: none; }
    .contact-form__btn,
    .contact-channel { transition: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contacto",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texto destacado (eyebrow)",
      "default": "Estamos aquí para ayudarte"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Título principal",
      "default": "Contáctanos"
    },
    {
      "type": "textarea",
      "id": "hero_text",
      "label": "Mensaje de invitación",
      "default": "Completa el formulario y te responderemos a la brevedad, o si lo prefieres, llámanos o escríbenos directamente por WhatsApp."
    },
    {
      "type": "header",
      "content": "Información de contacto"
    },
    {
      "type": "text",
      "id": "info_title",
      "label": "Título columna izquierda",
      "default": "¿Cómo podemos ayudarte?"
    },
    {
      "type": "textarea",
      "id": "info_text",
      "label": "Párrafo columna izquierda",
      "default": "Nuestro equipo está disponible para asesorarte sobre equipos de audio, soporte técnico, cotizaciones y más. No dudes en contactarnos por cualquier canal."
    },
    {
      "type": "text",
      "id": "email",
      "label": "Correo electrónico",
      "default": "danielmoyemanizales@gmail.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Teléfono",
      "default": "+57 300 000 0000"
    },
    {
      "type": "text",
      "id": "whatsapp",
      "label": "Número WhatsApp (con código de país)",
      "default": "+573000000000",
      "info": "Ejemplo: +573001234567"
    },
    {
      "type": "text",
      "id": "address",
      "label": "Ubicación",
      "default": "Pereira, Risaralda, Colombia"
    }
  ],
  "presets": [
    {
      "name": "Contacto"
    }
  ]
}
{% endschema %}
